# -----------------------------------------------------------------------------
# Dawn Is Always Ours environment template
# Copy to .env and fill values. Do not commit real secrets.
# -----------------------------------------------------------------------------

# Public app/share URL. Prefer the Telegram Mini App deep link in production.
NEXT_PUBLIC_TELEGRAM_APP_URL=

# Backward-compatible alias supported by lib/tg.ts.
NEXT_PUBLIC_TG_APP_URL=

# Browser fallback URL when not launched from Telegram.
NEXT_PUBLIC_APP_URL=

# TonConnect manifest. In production this must be an HTTPS URL on the same
# public app domain so mobile wallets such as Tonkeeper can fetch it.
NEXT_PUBLIC_TONCONNECT_MANIFEST_URL=

# Frontend API adapter. 
# NEXT_PUBLIC_API_BASE_URL: Leave blank in production for same-origin routing (frontend and backend deployed on the same domain), or set to "http://127.0.0.1:3001" for local wrangler emulation testing.
NEXT_PUBLIC_API_BASE_URL=
# NEXT_PUBLIC_USE_API_ADAPTER: Must be set to "true" to transition client service calls from local Mock fallbacks to the real Cloudflare Edge APIs.
NEXT_PUBLIC_USE_API_ADAPTER=false

# Exchange invitation links. These are public client-side links.
NEXT_PUBLIC_OKX_INVITE_URL=
NEXT_PUBLIC_BINANCE_INVITE_URL=
NEXT_PUBLIC_OKX_PLANET_URL=

# Telegram Mini App auth. Server-side only.
# TELEGRAM_BOT_TOKEN: Mandatory in production to perform secure SHA-256 HMAC verification of Telegram login data.
TELEGRAM_BOT_TOKEN=
# TELEGRAM_BOT_USERNAME: The username of your Telegram Bot (e.g., my_diao_bot).
TELEGRAM_BOT_USERNAME=
TELEGRAM_INITDATA_MAX_AGE_SECONDS=86400

# Cloudflare account/deploy. Server-side only.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_PAGES_PROJECT_NAME=
CLOUDFLARE_WORKER_NAME=gou-api

# Cloudflare D1 database binding. Server-side only.
CLOUDFLARE_D1_DATABASE_NAME=gou
CLOUDFLARE_D1_DATABASE_ID=23664c9d-9783-4457-839e-18e3074cd024

# Cloudflare R2 screenshot storage. Server-side only except public base URL.
CLOUDFLARE_R2_BUCKET_NAME=gou-loss-proofs
R2_BUCKET_BINDING=LOSS_PROOFS
R2_PUBLIC_BASE_URL=

# OCR strategy for loss screenshot review.
# Supported plan for first release: none | manual | cloudflare-workers-ai
OCR_PROVIDER=manual
CLOUDFLARE_AI_BINDING=AI
CLOUDFLARE_AI_MODEL=@cf/llava-hf/llava-1.5-7b-hf
CLOUDFLARE_AI_GATEWAY_URL=
AGNES_AI_BASE_URL=https://apihub.agnes-ai.com/v1
AGNES_AI_API_KEY=
AGNES_AI_MODEL=agnes-2.0-flash
AGNES_AI_VISION_MODEL=agnes-2.0-flash
AGNES_AI_TASK_VERIFY_MODEL=agnes-2.0-flash

# Optional token price source. Leave blank if DIAO is not live yet.
NEXT_PUBLIC_DIAO_TOKEN_SYMBOL=DIAO
DIAO_TOKEN_CHAIN=
DIAO_TOKEN_ADDRESS=
DIAO_MINTER_ADDRESS=
DIAO_VESTING_ADDRESS=
DIAO_JETTON_WALLET_CODE_HASH=
DIAO_METADATA_URL=
DIAO_MAINNET_DEPLOYER_WALLET=
DIAO_INITIAL_CIRCULATION_WALLET=
DIAO_OFFICIAL_RESERVE_WALLET=
DIAO_TREASURY_WALLET=
DIAO_EMERGENCY_RESCUE_WALLET=
DIAO_ADMIN_WALLET=
DIAO_PRICE_ADMIN_WALLET=
PRICE_PROVIDER=
PRICE_PROVIDER_API_KEY=

# TON RPC/indexer for purchase confirmation, claim confirmation, vesting state,
# and Jetton wallet balance reads. Use a production API key before launch.
TON_API_BASE_URL=https://toncenter.com/api/v2/jsonRPC
TON_API_KEY=
CHAIN_INDEXER_MODE=toncenter

# Official DIAO token sale. Public flags are client-visible; wallet values are
# not secrets but must be verified before production.
NEXT_PUBLIC_DIAO_SALE_ENABLED=false
# DIAO_SALE_TON_RECEIVER: Official destination address for receiving TON payments. Both receiver and team wallet must be configured to unblock payment.
DIAO_SALE_TON_RECEIVER=
# DIAO_TEAM_WALLET: The multi-sig team treasury wallet controlling allocations.
DIAO_TEAM_WALLET=
DIAO_SALE_MAX_PACKAGES_PER_WALLET=10
DIAO_SALE_MAX_PACKAGES_TOTAL=2000
DIAO_SALE_CONTRACT_GAS_BUFFER_TON=0.1

# Optional server session signing secret. Generate a long random value for prod.
SESSION_SECRET=
# Server-only token for loss-proof review APIs. Send as:
# Authorization: Bearer <ADMIN_REVIEW_TOKEN>
ADMIN_REVIEW_TOKEN=
