{
  "name": "my-project",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "pnpm exec eslint .",
    "typecheck": "pnpm exec tsc --noEmit",
    "cf:dev": "pnpm exec next-on-pages && node scripts/patch-cf-build.cjs && pnpm exec wrangler pages dev .vercel/output/static --compatibility-flag=nodejs_compat --d1 DB --r2 LOSS_PROOFS --port 3001",
    "cf:deploy": "pnpm exec next-on-pages && node scripts/patch-cf-build.cjs && pnpm exec wrangler pages deploy .vercel/output/static",
    "db:migrate:local": "pnpm exec wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "pnpm exec wrangler d1 migrations apply DB --remote",
    "verify:backend": "node scripts/verify-backend.cjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@ton/core": "^0.63.1",
    "@ton/crypto": "^3.3.0",
    "@ton/ton": "^16.3.0",
    "@tonconnect/ui-react": "^3.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "react": "^19",
    "react-dom": "^19",
    "shadcn": "^4.8.0",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@tailwindcss/postcss": "^4.2.0",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.6",
    "postcss": "^8.5",
    "tailwindcss": "^4.2.0",
    "typescript": "5.7.3",
    "wrangler": "^4.107.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd"
    ]
  }
}
